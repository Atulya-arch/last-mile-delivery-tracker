# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/delivery_tracker_db?schema=public"

# Auth Settings
JWT_SECRET="super-secret-development-key-change-in-production"
JWT_EXPIRES_IN=7d

# Email Settings (Optional - if omitted, mock mailing service will be used)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@deliverytracker.com
