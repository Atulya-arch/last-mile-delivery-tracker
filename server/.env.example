# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/delivery_tracker_db?schema=public"

# Auth Settings
JWT_SECRET="super-secret-development-key-change-in-production"
JWT_EXPIRES_IN=7d

# Email / Notification Settings (Optional - falls back to Ethereal mock/console logs if omitted)
# Option A: Resend HTTP API (Recommended for Render.app deployments)
RESEND_API_KEY=re_your_resend_api_key
SMTP_FROM="Last Mile Tracker <noreply@yourdomain.com>"

# Option B: SendGrid HTTP API
# SENDGRID_API_KEY=SG.your_sendgrid_api_key
# SMTP_FROM=your_verified_sender_email@gmail.com

# Option C: Legacy SMTP / Mail Server
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_gmail_address@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM="Last Mile Tracker <your_gmail_address@gmail.com>"
