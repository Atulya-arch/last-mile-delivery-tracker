datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  AGENT
  CUSTOMER
}

enum AgentStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum OrderType {
  B2B
  B2C
}

enum PaymentType {
  PREPAID
  COD
}

enum DeliveryStatus {
  CREATED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RESCHEDULED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(CUSTOMER)
  name         String
  phone        String
  isEmailVerified          Boolean   @default(false)
  emailVerificationOtp     String?
  emailVerificationExpires DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  agentProfile   AgentProfile?
  customerOrders DeliveryOrder[]         @relation("CustomerOrders")
  agentOrders    DeliveryOrder[]         @relation("AgentOrders")
  historyChanges TrackingHistory[]       @relation("UserHistoryChanges")

  @@map("users")
  @@index([role])
}

model AgentProfile {
  id            String      @id @default(uuid())
  userId        String      @unique
  zoneId        String?
  status        AgentStatus @default(OFFLINE)
  vehicleType   String
  licenseNumber String      @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone          Zone?       @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@map("agent_profiles")
  @@index([zoneId])
  @@index([status])
}

model Zone {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  areas          Area[]
  agentProfiles  AgentProfile[]
  pickupRates    RateCard[]      @relation("PickupZoneRates")
  dropRates      RateCard[]      @relation("DropZoneRates")

  @@map("zones")
}

model Area {
  id        String    @id @default(uuid())
  name      String    @unique
  zoneId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  zone         Zone            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  pickupOrders DeliveryOrder[] @relation("PickupArea")
  dropOrders   DeliveryOrder[] @relation("DropArea")

  @@map("areas")
  @@index([zoneId])
}

model RateCard {
  id              String    @id @default(uuid())
  pickupZoneId    String
  dropZoneId      String
  orderType       OrderType
  baseWeightLimit Float
  basePrice       Float
  pricePerKg      Float
  codSurcharge    Float
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  pickupZone      Zone      @relation("PickupZoneRates", fields: [pickupZoneId], references: [id], onDelete: Cascade)
  dropZone        Zone      @relation("DropZoneRates", fields: [dropZoneId], references: [id], onDelete: Cascade)

  @@unique([pickupZoneId, dropZoneId, orderType])
  @@map("rate_cards")
  @@index([pickupZoneId])
  @@index([dropZoneId])
}

model DeliveryOrder {
  id                    String         @id @default(uuid())
  orderNumber           String         @unique
  customerId            String
  agentId               String?
  pickupAreaId          String
  dropAreaId            String
  pickupAddress         String
  deliveryAddress       String
  length                Float
  width                 Float
  height                Float
  actualWeight          Float
  volumetricWeight      Float
  billableWeight        Float
  orderType             OrderType
  paymentType           PaymentType
  price                 Float
  status                DeliveryStatus @default(CREATED)
  notes                 String?
  failedReason          String?
  rescheduledCount      Int            @default(0)
  estimatedDeliveryTime DateTime?
  actualDeliveryTime    DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  deletedAt             DateTime?

  customer              User           @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  agent                 User?          @relation("AgentOrders", fields: [agentId], references: [id], onDelete: SetNull)
  pickupArea            Area           @relation("PickupArea", fields: [pickupAreaId], references: [id], onDelete: Restrict)
  dropArea              Area           @relation("DropArea", fields: [dropAreaId], references: [id], onDelete: Restrict)
  trackingHistory       TrackingHistory[]

  @@map("delivery_orders")
  @@index([customerId])
  @@index([agentId])
  @@index([pickupAreaId])
  @@index([dropAreaId])
  @@index([status])
}

model TrackingHistory {
  id          String         @id @default(uuid())
  orderId     String
  status      DeliveryStatus
  changedById String
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  order       DeliveryOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy   User           @relation("UserHistoryChanges", fields: [changedById], references: [id], onDelete: Restrict)

  @@map("tracking_histories")
  @@index([orderId])
  @@index([changedById])
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}
